    {
      "id": "body.brand-guidelines.li.3",
      "en": "Clear space: keep a margin on all sides equal to twice the logo height (same rule for the payoff version and for the symbol alone). Do not crowd type, photos, or UI against the mark.",
      "it": "",
      "source": "brand-guidelines.html",
      "context": "<li>"
    },
    {
      "id": "body.brand-guidelines.li.4",
      "en": "Also approved when needed: Starter Yellow on a light field (e.g. Crystal White) — use the same mask technique as below. Do not introduce colours outside this system.",
      "it": "",
      "source": "brand-guidelines.html",
      "context": "<li>"
    },
    {
      "id": "body.brand-guidelines.li.5",
      "en": "Do not distort, outline, tilt, add shadows or glows. Wordmark and symbol must use the same colour treatment in a given layout.",
      "it": "",
      "source": "brand-guidelines.html",
      "context": "<li>"
    },
    {
