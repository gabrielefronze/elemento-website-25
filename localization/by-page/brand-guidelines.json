    {
      "id": "body.brand-guidelines.p.3",
      "en": "These guidelines align with the official Branding Guidelines — Elemento Modular Cloud (logo, trademark, typography, colour, imagery). They summarize rules for web and partner use. When in doubt, match the homepage and about story, and preserve each mark’s aspect ratio.",
      "it": "",
      "source": "brand-guidelines.html",
      "context": "<p>"
    },
