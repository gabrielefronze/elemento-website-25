    {
      "id": "body.c4-protocol.p.1",
      "en": "Common Cloud Compute Connector Protocol",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.10",
      "en": "One operational language for Electros across all connected environments.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.11",
      "en": "Provision, move and govern workloads through federation contracts.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.12",
      "en": "C4 acts as a translation layer between Electros and provider-specific APIs.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.13",
      "en": "Each provider exposes its capabilities through C4, allowing Electros to issue common federation operations without requiring knowledge of the underlying provider implementation.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.14",
      "en": "Metacloud Control Plane",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.15",
      "en": "Translation Layer",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.16",
      "en": "C4 evolves toward intent-driven infrastructure and autonomous federation.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.2",
      "en": "The Common Language of the Metacloud. C4 is the interoperability framework that allows heterogeneous infrastructure platforms to participate in one federation model.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.3",
      "en": "C4 does not replace provider APIs.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.4",
      "en": "It provides a common language that translates federation operations into provider-specific operations, preserving existing technology choices while enabling a unified operational framework.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.5",
      "en": "Declare an outcome through portable C4 contracts. The Metacloud identifies and activates the most suitable implementation.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.6",
      "en": "Normalise heterogeneous provider capabilities into a common model.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.7",
      "en": "Make infrastructure and services discoverable across the federation.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.8",
      "en": "Register providers, hypervisors and services into the Metacloud.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
    {
      "id": "body.c4-protocol.p.9",
      "en": "Expose provider-specific features through a unified interface.",
      "it": "",
      "fr": "",
      "source": "c4-protocol.html",
      "context": "<p>"
    },
