      "fr": "",
      "source": "platform.html",
      "context": "<p>"
    },
    {
      "id": "body.platform.p.14",
      "en": "Electros federates resources through one governance and orchestration model.",
      "it": "",
      "fr": "",
      "source": "platform.html",
      "context": "<p>"
    },
    {
