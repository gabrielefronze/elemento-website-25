    },
    {
      "id": "body.atomosphere.p.13",
      "en": "Universal API abstraction layer for existing CSP accounts",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.14",
      "en": "Operators learn one API — Elemento's — while the proxy handles translation to AWS , Azure , GCP , on-prem KVM , and more.",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.15",
      "en": "Electros UI surfaces cost-per-VM metrics across your CSP accounts. Atomosphere helps you identify the best-priced resources across providers in real-time.",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.16",
      "en": "Launch a VM wherever you choose, all through the same dashboard or script — cloud-agnostic PaaS provisioning .",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.17",
      "en": "10+ major CSPs supported today, with ongoing API integrations and custom provider support for enterprise customers.",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
