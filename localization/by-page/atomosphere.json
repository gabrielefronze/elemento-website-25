    {
      "id": "body.atomosphere.p.1",
      "en": "Instead of learning separate APIs for AWS, Azure, Google Cloud, and other CSPs, Atomosphere provides one API to rule them all while you continue using your existing cloud accounts.",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.10",
      "en": "Cost Comparison",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.11",
      "en": "Your cloud flow: Electros UI/CLI ⇄ Elemento API proxy ⇄ your existing AWS/Azure/GCP accounts",
      "it": "",
      "source": "atomosphere.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosphere.p.12",
