    {
      "id": "body.atomosquare.p.1",
      "en": "Universal Hypervisor Fabric",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.10",
      "en": "Hypervisor-side components operate independently while exposing common capabilities.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.11",
      "en": "Enable common governance, orchestration and resource discovery across multiple virtualization platforms.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.12",
      "en": "Expose private infrastructure resources to Electros.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.13",
      "en": "Make hypervisor-backed capabilities available through the Metacloud operating model.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.14",
      "en": "Atomosquare prevents VMware exit from becoming another lock-in cycle.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.15",
      "en": "Instead of forcing a one-time migration into a new hypervisor silo, Atomosquare allows legacy and new environments to be governed under the same control plane.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.16",
      "en": "AtomOS is Elemento's native sovereign virtualization endpoint inside Atomosquare.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.17",
      "en": "VMware, Proxmox, Nutanix, Hyper-V and OpenStack are third-party endpoints inside the same fabric.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.18",
      "en": "Electros governs both native and third-party environments through the same operational model.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.19",
      "en": "Hypervisor Fabric",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.2",
      "en": "Atomosquare connects hypervisors, virtualization platforms and private cloud infrastructures to the Elemento Metacloud.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.3",
      "en": "Atomosquare is the distributed hypervisor connectivity layer of the Elemento platform.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.4",
      "en": "It consists of hypervisor-side connectors and federation endpoints that expose virtualization platforms and private cloud infrastructures to the Metacloud through a common interoperability model.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.5",
      "en": "Rather than replacing existing virtualization environments, Atomosquare enables heterogeneous hypervisors to participate in a common federation while preserving operational independence.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.6",
      "en": "Atomosquare is not itself a hypervisor — it is the connectivity fabric that joins hypervisors to Electros.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.7",
      "en": "Common governance, orchestration and resource discovery across multiple virtualization platforms.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.8",
      "en": "Connect heterogeneous virtualization platforms into the federation.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
    {
      "id": "body.atomosquare.p.9",
      "en": "Allow hypervisors and private cloud environments to participate without changing internal operations.",
      "it": "",
      "fr": "",
      "source": "atomosquare.html",
      "context": "<p>"
    },
