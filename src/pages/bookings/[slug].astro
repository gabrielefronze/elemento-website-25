---
import MigratedPage from '../../components/MigratedPage.astro';
import { pagesByGroup } from '../../lib/manifest';

export function getStaticPaths() {
  return pagesByGroup('bookings', 'en').map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<MigratedPage entry={entry} locale="en" />
