---
import { switchLocalePath } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { getUi } from '../i18n';

interface Props {
  locale: Locale;
  stem: string;
  assetBase?: string;
}

const { locale, stem, assetBase = '' } = Astro.props;
const ui = getUi(locale);
const enHref = switchLocalePath(locale, 'en', stem);
const itHref = switchLocalePath(locale, 'it', stem);
const flag = (code: string) => `${assetBase}assets/flags/${code}.svg`;
---

<div class="lang-switcher" role="navigation" aria-label={ui.langSwitcher.label}>
  <a
    href={enHref}
    class:list={['lang-switcher__link', { 'lang-switcher__link--active': locale === 'en' }]}
    hreflang="en"
    lang="en"
    aria-label={ui.langSwitcher.enAria}
    title={ui.langSwitcher.enAria}
  >
    <img class="lang-switcher__flag" src={flag('gb')} alt="" width="24" height="16" loading="lazy" decoding="async" />
  </a>
  <a
    href={itHref}
    class:list={['lang-switcher__link', { 'lang-switcher__link--active': locale === 'it' }]}
    hreflang="it"
    lang="it"
    aria-label={ui.langSwitcher.itAria}
    title={ui.langSwitcher.itAria}
  >
    <img class="lang-switcher__flag" src={flag('it')} alt="" width="24" height="16" loading="lazy" decoding="async" />
  </a>
</div>
